# Server
NODE_ENV=development
PORT=5000

# Required: your Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Caps how many tokens Gemini spends "thinking" before it starts producing
# visible output (0 = disabled, -1 = fully dynamic/model-decided up to 8192,
# N = hard cap). Left unset, 2.5-series models default to an uncapped dynamic
# budget, which is the main source of the multi-second delay before analysis
# starts streaming. 1024 keeps real per-clause legal judgment while bounding
# the worst case; raise it if you notice shallower reasoning on complex
# contracts, lower it (or set to 0) to push for more speed.
GEMINI_THINKING_BUDGET=1024

# Optional: enables persistence of past analyses (the "M" in MERN).
# Leave unset to run the app fully stateless with history disabled.
# Local:  mongodb://127.0.0.1:27017/nyayai
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/nyayai
MONGODB_URI=mongodb://127.0.0.1:27017/nyayai

# Comma-separated list of allowed frontend origins, or "*" for any origin
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=info
JSON_BODY_LIMIT=15mb
